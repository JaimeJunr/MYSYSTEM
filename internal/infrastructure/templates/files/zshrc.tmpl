# Generated by Homestead
# Date: {{ .GeneratedAt }}
{{ if .HasPowerlevel10k }}
# Powerlevel10k instant prompt (keep at top)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi
{{ end }}
{{ if .HasOhMyZsh }}export ZSH="$HOME/.oh-my-zsh"
{{ end }}
{{ if .HasPowerlevel10k }}ZSH_THEME="powerlevel10k/powerlevel10k"
{{ end }}
{{ if .Plugins }}plugins=({{ range $i, $p := .Plugins }}{{ if $i }} {{ end }}{{ $p }}{{ end }})
{{ end }}
{{ if .HasOhMyZsh }}source "$ZSH/oh-my-zsh.sh"
{{ end }}
{{ if .HasNVM }}
# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
{{ end }}
{{ if .HasBun }}
# Bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
{{ end }}
{{ if .HasSDKMAN }}
# SDKMAN
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]] && source "$SDKMAN_DIR/bin/sdkman-init.sh"
{{ end }}
{{ if .HasPNPM }}
# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PNPM_HOME:$PATH"
{{ end }}
{{ if .HasDeno }}
# Deno
export DENO_INSTALL="$HOME/.deno"
export PATH="$DENO_INSTALL/bin:$PATH"
{{ end }}
{{ if .HasHomebrew }}
# Homebrew
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end }}
{{ if .HasPyenv }}
# pyenv
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"
{{ end }}
{{ if .HasCargo }}
# Cargo (Rust)
export PATH="$HOME/.cargo/bin:$PATH"
{{ end }}

# General configuration
[[ -f ~/.zsh/general/aliases.zsh ]] && source ~/.zsh/general/aliases.zsh
[[ -f ~/.zsh/general/functions.zsh ]] && source ~/.zsh/general/functions.zsh
{{ if .IncludeProjectConfig }}
# Project-specific configuration
[[ -f ~/.zsh/projects/ivt.zsh ]] && source ~/.zsh/projects/ivt.zsh
{{ end }}
{{ if .HasPowerlevel10k }}
# Powerlevel10k config
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
{{ end }}
